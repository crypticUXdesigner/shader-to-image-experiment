  let n101 = noise_hash11(dot(ip + vec3<f32>(1.0, 0.0, 1.0), vec3<f32>(1.0, 57.0, 113.0)));
  let n011 = noise_hash11(dot(ip + vec3<f32>(0.0, 1.0, 1.0), vec3<f32>(1.0, 57.0, 113.0)));
