  let skyHighRgb = dhlOklchToRgb(vec3<f32>(skyHighL, skyHighC, skyHighH));
  let skyTint = mix(skyLowRgb, skyHighRgb, skyT);
  col = col + skyT * skyTint * skyStrength;
