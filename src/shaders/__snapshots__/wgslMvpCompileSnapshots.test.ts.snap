fn mandelbx_sphere_fold(z: vec3<f32>, min_r2: f32, fold_l2: f32) -> vec3<f32> {
  let r2 = dot(z, z);
  let k = min(max(fold_l2 / max(min_r2, r2), 1.0), 1e4);
  return z * k;
}

fn mandelbox_sdf_distance(
  p0: vec3<f32>,
  scale_mb: f32,
  folding_limit: f32,
