fn kifs_sdf_distance(
  p0: vec3<f32>,
  scale_in: f32,
  offset: vec3<f32>,
  rot: mat3x3<f32>,
  iterations_in: i32,
  radius: f32,
) -> f32 {
  let rot_rt = transpose(rot);
  var p = p0;
  var total_scale = 1.0;
