  if (z.y + z.z < 0.0) { z = vec3<f32>(z.x, -z.z, -z.y); }
  return z;
}

fn ster_tetra_distance(
  p_world: vec3<f32>,
  pre_rot_st: mat3x3<f32>,
  scl_ift: f32,
  ofs_ift: vec3<f32>,
  iters_ift: i32,
