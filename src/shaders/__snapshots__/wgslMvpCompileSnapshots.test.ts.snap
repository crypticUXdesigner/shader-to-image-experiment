}

fn dhl_EnvironmentLights(ro: vec3<f32>, rd: vec3<f32>, i: f32, t: f32) -> vec3<f32> {
  let n = dhl_N(i + floor(t));
  let side = sign(rd.x);
  let offset = max(side, 0.0) * (1.0 / 16.0);
  let z = fract(i - t + offset + fract(n * 234.0));
  let n2 = fract(n * 100.0);
