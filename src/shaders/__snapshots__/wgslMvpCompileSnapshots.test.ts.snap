}

fn noise_permute_3d(x: vec4<f32>) -> vec4<f32> {
  return noise_mod289_3d4(((x * 34.0) + 1.0) * x);
}

fn noise_taylorInvSqrt_3d(r: vec4<f32>) -> vec4<f32> {
