}

fn etherSdfRot2(a: f32) -> mat2x2<f32> {
  let c = cos(a);
  let s = sin(a);
  return mat2x2<f32>(vec2<f32>(c, -s), vec2<f32>(s, c));
}

fn etherSdfMap(pIn: vec3<f32>, t: f32, rotXZ: f32, rotXY: f32, scale: f32, wobble: f32, sineAmp: f32) -> f32 {
