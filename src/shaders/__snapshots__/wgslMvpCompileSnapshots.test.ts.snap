@group(0) @binding(0) var<uniform> globals : Globals;
@group(0) @binding(1) var<storage, read> params : array<vec4<f32>>;

struct VsOut {
  @builtin(position) pos : vec4<f32>,
  @location(0) uv : vec2<f32>,
}

@vertex
fn vs(@builtin(vertex_index) vid : u32) -> VsOut {
  var p = array<vec2<f32>, 3>(
    vec2<f32>(-1.0, -1.0),
    vec2<f32>( 3.0, -1.0),
    vec2<f32>(-1.0,  3.0)
  );
  var o : VsOut;
  o.pos = vec4<f32>(p[vid], 0.0, 1.0);
  o.uv = (o.pos.xy * 0.5) + vec2<f32>(0.5, 0.5);
  return o;
}

fn fractalDeformWgsl(p: vec2<f32>, time: f32, intensity: f32, layers: f32, iterations: i32, timeOffset: f32, animationSpeed: f32, rotationSpeed: f32, layerPhase: f32) -> f32 {
  var z = p;
  var scale = 1.0;
  var value = 0.0;
  let layerScale = max(layers, 0.0001);
  let t = (time + timeOffset) * animationSpeed;

  for (var i = 0; i < 16; i = i + 1) {
    if (i >= iterations) { break; }

    let angle = t * rotationSpeed + f32(i) * layerPhase;
    let c = cos(angle);
    let s = sin(angle);
    z = vec2<f32>(z.x * c - z.y * s, z.x * s + z.y * c);

    z = abs(z);
    if (z.x < z.y) {
      z = z.yx;
    }
    z = z * layerScale - vec2<f32>(1.0, 1.0);
    scale = scale * layerScale;

    value = value + exp(-length(z) * scale);
  }

  return value * intensity;
}
@fragment
fn fs(in : VsOut) -> @location(0) vec4<f32> {
  return vec4<f32>((fractalDeformWgsl(((in.uv * 2.0 - vec2<f32>(1.0, 1.0)) * vec2<f32>((globals.v0.z / max(1.0, globals.v0.w)), 1.0)) * 2.0, globals.v0.x, params[1].x, params[4].x, clamp(i32(params[2].x + 0.5), 1, 16), params[6].x, params[0].x, params[5].x, params[3].x) * 0.3), (fractalDeformWgsl(((in.uv * 2.0 - vec2<f32>(1.0, 1.0)) * vec2<f32>((globals.v0.z / max(1.0, globals.v0.w)), 1.0)) * 2.0, globals.v0.x, params[1].x, params[4].x, clamp(i32(params[2].x + 0.5), 1, 16), params[6].x, params[0].x, params[5].x, params[3].x) * 0.3), (fractalDeformWgsl(((in.uv * 2.0 - vec2<f32>(1.0, 1.0)) * vec2<f32>((globals.v0.z / max(1.0, globals.v0.w)), 1.0)) * 2.0, globals.v0.x, params[1].x, params[4].x, clamp(i32(params[2].x + 0.5), 1, 16), params[6].x, params[0].x, params[5].x, params[3].x) * 0.3), 1.0);
}
",
