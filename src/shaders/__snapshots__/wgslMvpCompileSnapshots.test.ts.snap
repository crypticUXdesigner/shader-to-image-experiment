exports[`WGSL MVP compile snapshots > matches snapshot for mvpDots 1`] = `
{
  "code": "
struct Globals {
  v0 : vec4<f32>,
  v1 : vec4<f32>,
}

@group(0) @binding(0) var<uniform> globals : Globals;
@group(0) @binding(1) var<storage, read> params : array<vec4<f32>>;

struct VsOut {
  @builtin(position) pos : vec4<f32>,
  @location(0) uv : vec2<f32>,
}

@vertex
fn vs(@builtin(vertex_index) vid : u32) -> VsOut {
  var p = array<vec2<f32>, 3>(
    vec2<f32>(-1.0, -1.0),
    vec2<f32>( 3.0, -1.0),
    vec2<f32>(-1.0,  3.0)
  );
  var o : VsOut;
  o.pos = vec4<f32>(p[vid], 0.0, 1.0);
  o.uv = (o.pos.xy * 0.5) + vec2<f32>(0.5, 0.5);
  return o;
}

fn dotsPattern(p: vec2<f32>, gap: f32, dotRadiusWorld: f32, featherUv: f32) -> f32 {
  let g = max(0.0, gap);
  let period = max(1e-5, 2.0 * dotRadiusWorld + g);
  let cell = fract(p / period);
  let center = vec2<f32>(0.5, 0.5);
  let dist = length(cell - center);
  let radiusCell = dotRadiusWorld / period;
  let featherCell = featherUv / period;
  return 1.0 - smoothstep(radiusCell, radiusCell + featherCell, dist);
}
@fragment
fn fs(in : VsOut) -> @location(0) vec4<f32> {
  return vec4<f32>((dotsPattern(((in.uv * 2.0 - vec2<f32>(1.0, 1.0)) * vec2<f32>((globals.v0.z / max(1.0, globals.v0.w)), 1.0)), params[1].x, params[3].x, params[0].x) * params[2].x), (dotsPattern(((in.uv * 2.0 - vec2<f32>(1.0, 1.0)) * vec2<f32>((globals.v0.z / max(1.0, globals.v0.w)), 1.0)), params[1].x, params[3].x, params[0].x) * params[2].x), (dotsPattern(((in.uv * 2.0 - vec2<f32>(1.0, 1.0)) * vec2<f32>((globals.v0.z / max(1.0, globals.v0.w)), 1.0)), params[1].x, params[3].x, params[0].x) * params[2].x), 1.0);
}
",
  "fixtureId": "mvpDots",
  "paramLayout": {
    "n-d.dotsFeather": 0,
    "n-d.dotsGap": 1,
    "n-d.dotsIntensity": 2,
    "n-d.dotsSize": 3,
  },
  "previewDependencies": {
    "usesAudioUniforms": false,
    "usesFrameIndex": false,
