      let cosHit = cos(vec4<f32>(d / 0.1) + vec4<f32>(0.0, 2.0, 4.0, 0.0));
      acc = acc + ((cosHit + vec4<f32>(1.0)) / 0.001) * max(t, 0.01) * glowMult;
