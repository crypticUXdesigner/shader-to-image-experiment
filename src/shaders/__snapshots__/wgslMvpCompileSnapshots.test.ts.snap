fn fs(in : VsOut) -> @location(0) vec4<f32> {
  return vec4<f32>((((sfId2Dir(round(sfDir2Id(select(vec3<f32>(0.0, 0.0, 1.0), normalize(vec3<f32>(params[1].x, params[2].x, params[3].x)), length(vec3<f32>(params[1].x, params[2].x, params[3].x)) > 0.001), min(max(f32(params[14].x), 2.0), 4096.0))), min(max(f32(params[14].x), 2.0), 4096.0))).x * params[4].x) + (vec3<f32>(params[7].x, params[8].x, params[9].x)).x), (((sfId2Dir(round(sfDir2Id(select(vec3<f32>(0.0, 0.0, 1.0), normalize(vec3<f32>(params[1].x, params[2].x, params[3].x)), length(vec3<f32>(params[1].x, params[2].x, params[3].x)) > 0.001), min(max(f32(params[14].x), 2.0), 4096.0))), min(max(f32(params[14].x), 2.0), 4096.0))).x * params[4].x) + (vec3<f32>(params[7].x, params[8].x, params[9].x)).x), (((sfId2Dir(round(sfDir2Id(select(vec3<f32>(0.0, 0.0, 1.0), normalize(vec3<f32>(params[1].x, params[2].x, params[3].x)), length(vec3<f32>(params[1].x, params[2].x, params[3].x)) > 0.001), min(max(f32(params[14].x), 2.0), 4096.0))), min(max(f32(params[14].x), 2.0), 4096.0))).x * params[4].x) + (vec3<f32>(params[7].x, params[8].x, params[9].x)).x), 1.0);
}
