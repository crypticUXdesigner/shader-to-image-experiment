{
    "name": "shadernoice",
    "version": "1.0.0",
    "type": "module",
    "description": "A web-based tool for generating abstract art images using composable WebGL shader visual elements",
    "repository": {
        "type": "git",
        "url": "https://github.com/crypticUXdesigner/ShaderNoice.git"
    },
    "homepage": "https://crypticUXdesigner.github.io/ShaderNoice/",
    "keywords": [
        "shader",
        "webgl",
        "glsl",
        "procedural",
        "art",
        "generator",
        "visual",
        "composer"
    ],
    "license": "UNLICENSED",
    "scripts": {
        "dev": "vite",
        "type-check": "tsc --noEmit",
        "build": "tsc && vite build",
        "test": "vitest run",
        "test:webgpu-golden": "tsx scripts/webgpu-golden-parity.ts",
        "check": "npm run type-check && npm test && npm run lint",
        "verify:pages": "npm audit --audit-level=high && npm run check && npm run build && npm run build-storybook && npm run test:value-input-chromium",
        "preview": "vite preview",
        "migrate": "tsx scripts/migrate.ts",
        "build-phosphor-icons": "tsx scripts/build-phosphor-icons.ts",
        "build-favicons": "tsx scripts/build-favicons.ts",
        "lint": "eslint \"src/**/*.{ts,svelte}\" \"scripts/**/*.ts\" \".storybook/**/*.{ts,svelte}\"",
        "a11y": "tsx scripts/a11y.ts",
        "test:value-input-chromium": "tsx scripts/value-input-doubleclick-chromium.ts",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "generate-stories": "tsx scripts/generate-svelte-stories.ts"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@storybook/addon-a11y": "^10.3.3",
        "@storybook/addon-docs": "^10.3.3",
        "@storybook/addon-svelte-csf": "^5.1.0",
        "@storybook/svelte-vite": "^10.3.3",
        "@types/node": "^20.10.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@webgpu/types": "^0.1.69",
        "eslint": "^10.0.2",
        "eslint-plugin-svelte": "^3.15.0",
        "fake-indexeddb": "^6.2.5",
        "playwright": "^1.58.2",
        "png-to-ico": "^3.0.1",
        "sharp": "^0.33.5",
        "storybook": "^10.3.3",
        "svelte-eslint-parser": "^1.5.1",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "wait-on": "^9.0.4"
    },
    "overrides": {
        "undici": "^6.24.0"
    },
    "dependencies": {
        "@audiotool/nexus": ">=0.0.15",
        "@connectrpc/connect": "^1.7.0",
        "@connectrpc/connect-web": "^1.7.0",
        "@phosphor-icons/core": "^2.1.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "mediabunny": "^1.31.0",
        "svelte": "^5.50.0",
        "web-vitals": "^5.1.0"
    }
}
